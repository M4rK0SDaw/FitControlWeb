@model FitControlWeb.ViewModels.Usuarios.UsuarioIndexViewModel

@{
    ViewData["Title"] = "Usuarios";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Usuarios</h2>
            <p class="text-muted mb-0">Gestion de usuarios del sistema</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Create" class="btn btn-orange">
                <i class="bi bi-person-plus me-1"></i> Nuevo usuario
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-primary">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <span class="info-label">Total usuarios</span>
                    <p class="info-value mb-0">@Model.TotalUsuarios</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <span class="info-label">Activos</span>
                    <p class="info-value mb-0">@Model.UsuariosActivos</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-danger">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <span class="info-label">Inactivos</span>
                    <p class="info-value mb-0">@Model.UsuariosInactivos</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-warning">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <span class="info-label">Clientes</span>
                    <p class="info-value mb-0">@Model.TotalClientes</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-info">
                    <i class="bi bi-person-workspace"></i>
                </div>
                <div>
                    <span class="info-label">Entrenadores</span>
                    <p class="info-value mb-0">@Model.TotalEntrenadores</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-dark">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <span class="info-label">Administradores</span>
                    <p class="info-value mb-0">@Model.TotalAdministradores</p>
                </div>
            </div>
        </div>

        <div class="col-md-12 col-xl-4">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-secondary">
                    <i class="bi bi-calendar-plus"></i>
                </div>
                <div>
                    <span class="info-label">Nuevos este mes</span>
                    <p class="info-value mb-0">@Model.NuevosEsteMes</p>
                </div>
            </div>
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Nombre, email..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Rol</label>
                <select name="rolId" class="form-select" asp-items="Model.Roles">
                    <option value="">Todos</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Estado</label>
                <select name="activo" class="form-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.Activo == true)">Activos</option>
                    <option value="false" selected="@(Model.Activo == false)">Inactivos</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-1 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>

        <br />
        <partial name="_ExportButtons" model="Model.ExportButtons" />
    </div>

    @if (!Model.Usuarios.Any())
    {
        <div class="alert alert-info">
            No hay usuarios con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var usuario in Model.Usuarios)
                    {
                        <tr>
                            <td>@usuario.Nombre @usuario.Apellidos</td>
                            <td>@usuario.Email</td>
                            <td>@usuario.Rol</td>
                            <td>
                                <span class="badge @(usuario.Activo ? "bg-success" : "bg-danger")">
                                    @(usuario.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (usuario.Activo)
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@usuario.Id"
                                              method="post"
                                              class="d-inline form-delete">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-delete">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivar"
                                              asp-route-id="@usuario.Id"
                                              method="post"
                                              class="d-inline form-reactivar">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-outline-success btn-reactivar">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                <span class="text-muted small">
                    Pagina @Model.CurrentPage de @Model.TotalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="1"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-rolId="@Model.RolId"
                               asp-route-activo="@Model.Activo">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-rolId="@Model.RolId"
                               asp-route-activo="@Model.Activo">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-rolId="@Model.RolId"
                                   asp-route-activo="@Model.Activo">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-rolId="@Model.RolId"
                               asp-route-activo="@Model.Activo">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@Model.TotalPages"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-rolId="@Model.RolId"
                               asp-route-activo="@Model.Activo">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Dar de baja usuario?',
                    text: 'El usuario quedara inactivo.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Si',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar usuario?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonText: 'Cancelar',
                    confirmButtonText: 'Si'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });
    </script>
}
