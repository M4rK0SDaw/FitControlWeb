@model IEnumerable<FitControlWeb.ViewModels.UsuarioListViewModel>
@using FitControlWeb.ViewModels.Shared

@{
    ViewData["Title"] = "Usuarios";

    var usuarios = Model?.ToList() ?? new List<FitControlWeb.ViewModels.UsuarioListViewModel>();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalUsuarios = ViewBag.TotalUsuarios ?? 0;
    
    int usuariosActivos = ViewBag.UsuariosActivos ?? 0;
    int usuariosInactivos = ViewBag.UsuariosInactivos ?? 0;
    int totalClientes = ViewBag.TotalClientes ?? 0;


    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <!-- HEADER -->
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Usuarios</h2>
            <p class="text-muted mb-0">Gestión de usuarios del sistema</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Create" class="btn btn-orange">
                <i class="bi bi-person-plus me-1"></i> Nuevo usuario
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-primary">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <span class="info-label">Total usuarios</span>
                    <p class="info-value mb-0">@totalUsuarios</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <span class="info-label">Activos</span>
                    <p class="info-value mb-0">@usuariosActivos</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-danger">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <span class="info-label">Inactivos</span>
                    <p class="info-value mb-0">@usuariosInactivos</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box d-flex align-items-center gap-3">
                <div class="kpi-icon bg-warning">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <span class="info-label">Clientes</span>
                    <p class="info-value mb-0">@totalClientes</p>
                </div>
            </div>
        </div>

    </div>
    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Nombre, email..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Rol</label>
                <select name="rolId" class="form-select" asp-items="ViewBag.Roles">
                    <option value="">Todos</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Estado</label>
                <select name="activo" class="form-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(ViewBag.Activo?.ToString() == "True")">Activos</option>
                    <option value="false" selected="@(ViewBag.Activo?.ToString() == "False")">Inactivos</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-1 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>

        </form>
        <br />
        @{
            var exportModel = new ExportButtonsViewModel
            {
                Controller = "Usuarios",
                ExcelAction = "ExportExcel",
                CsvAction = "ExportCsv",
                PdfAction = "ExportPdf",
                RouteValues = new Dictionary<string, string?>
        {
            { "search", ViewBag.Search?.ToString() },
            { "rolId", ViewBag.RolId?.ToString() },
            { "activo", ViewBag.Activo?.ToString() }
        }
            };
        }

        <partial name="_ExportButtons" model="exportModel" />
    </div>

    
    @if (!usuarios.Any())
    {
        <div class="alert alert-info">
            No hay usuarios con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var u in usuarios)
                    {
                        <tr>
                            <td>@u.Nombre @u.Apellidos</td>
                            <td>@u.Email</td>
                            <td>@u.Rol</td>

                            <td>
                                <span class="badge @(u.Activo ? "bg-success" : "bg-danger")">
                                    @(u.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="btn-group">

                                    <!-- VER -->
                                    <a asp-action="Details"
                                           asp-route-id="@u.Id"
                                           class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <!-- EDIT -->
                                    <a asp-action="Edit"
                                           asp-route-id="@u.Id"
                                           class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- DELETE / REACTIVAR -->
                                    @if (u.Activo)
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@u.Id"
                                              method="post"
                                              class="d-inline form-delete">

                                            @Html.AntiForgeryToken()

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-delete">
                                                <i class="bi bi-x-circle"></i>
                                            </button>

                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivar"
                                              asp-route-id="@u.Id"
                                              method="post"
                                              class="d-inline form-reactivar">

                                            @Html.AntiForgeryToken()

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-reactivar">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>

                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINACIÓN -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">

                <span class="text-muted small">
                    Página @currentPage de @totalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="1"
                               asp-route-pageSize="@pageSize"
                               asp-route-search="@ViewBag.Search"
                               asp-route-rolId="@ViewBag.RolId"
                               asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-pageSize="@pageSize"
                               asp-route-search="@ViewBag.Search"
                               asp-route-rolId="@ViewBag.RolId"
                               asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@pageSize"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-rolId="@ViewBag.RolId"
                                       asp-route-activo="@ViewBag.Activo">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-pageSize="@pageSize"
                               asp-route-search="@ViewBag.Search"
                               asp-route-rolId="@ViewBag.RolId"
                               asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@totalPages"
                               asp-route-pageSize="@pageSize"
                               asp-route-search="@ViewBag.Search"
                               asp-route-rolId="@ViewBag.RolId"
                               asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Dar de baja usuario?',
                    text: 'El usuario quedará inactivo.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar usuario?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonText: 'Cancelar',
                    confirmButtonText: 'Sí'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });
    </script>
}