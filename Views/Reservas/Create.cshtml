@model FitControlWeb.ViewModels.UsuarioCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Nuevo usuario";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" />
}

<div class="page-card">
    <div class="page-header">
        <h2 class="page-title">Nuevo usuario</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 d-none" data-fit-validation-toast="true"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Apellidos" class="form-label"></label>
                <input asp-for="Apellidos" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="RolId" class="form-label">Rol</label>
                <select asp-for="RolId" asp-items="ViewBag.Roles" class="form-select"></select>
            </div>

            <div class="col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" />
            </div>
        </div>

        <button class="btn btn-orange mt-4">Guardar usuario</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
