@model IEnumerable<FitControlWeb.Models.Entities.Especialidad>

@{
    ViewData["Title"] = "Especialidades";

    var especialidades = Model?.ToList() ?? new List<FitControlWeb.Models.Entities.Especialidad>();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalEspecialidades = ViewBag.TotalEspecialidades ?? 0;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Especialidades</h2>
            <p class="text-muted mb-0">Gestión de especialidades de clases</p>
        </div>

        <a asp-action="Create" class="btn btn-orange">
            <i class="bi bi-plus-circle me-1"></i> Nueva especialidad
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="info-box">
                <span class="info-label">Especialidades encontradas</span>
                <p class="info-value mb-0">@totalEspecialidades</p>
            </div>
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">

            <div class="col-md-5">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Nombre de especialidad..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="activo" class="form-select">
                    <option value="">Todas</option>
                    <option value="true" selected="@(ViewBag.Activo?.ToString() == "True")">Activas</option>
                    <option value="false" selected="@(ViewBag.Activo?.ToString() == "False")">Inactivas</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search"></i>
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>

    @if (!especialidades.Any())
    {
        <div class="alert alert-info">
            No hay especialidades con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var e in especialidades)
                    {
                        <tr>
                            <td class="fw-semibold">@e.Nombre</td>

                            <td>
                                <span class="badge @(e.Activo == true ? "bg-success" : "bg-danger")">
                                    @(e.Activo == true ? "Activa" : "Inactiva")
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="btn-group">

                                    <a asp-action="Details"
                                           asp-route-id="@e.Id"
                                           class="btn btn-sm btn-outline-dark"
                                           title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@e.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (e.Activo == true)
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@e.Id"
                                              method="post"
                                              class="d-inline form-delete">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-delete"
                                                    title="Dar de baja">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivar"
                                              asp-route-id="@e.Id"
                                              method="post"
                                              class="d-inline form-reactivar">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-reactivar"
                                                    title="Reactivar">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                <span class="text-muted small">
                    Página @currentPage de @totalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@pageSize"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-activo="@ViewBag.Activo">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-delete').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Dar de baja especialidad?',
                    text: 'La especialidad quedará inactiva.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, dar de baja',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar especialidad?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, reactivar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}