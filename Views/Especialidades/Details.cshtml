@model FitControlWeb.Models.Entities.Especialidad

@{
    ViewData["Title"] = "Detalle de especialidad";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">@Model.Nombre</h2>
            <p class="text-muted mb-0">Información completa de la especialidad</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-orange">
                <i class="bi bi-pencil"></i> Editar
            </a>

            @if (Model.Activo == true)
            {
                <form asp-action="Delete"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="d-inline form-delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Especialidades")" />

                    <button type="button" class="btn btn-outline-danger btn-delete">
                        <i class="bi bi-x-circle"></i> Dar de baja
                    </button>
                </form>
            }
            else
            {
                <form asp-action="Reactivar"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="d-inline form-reactivar">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                    <button type="button" class="btn btn-outline-success btn-reactivar">
                        <i class="bi bi-arrow-clockwise"></i> Reactivar
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="info-box">
        <h5 class="fw-bold mb-3">Datos</h5>

        <div class="row g-3">
            <div class="col-md-6">
                <span class="info-label">Nombre</span>
                <p class="info-value">@Model.Nombre</p>
            </div>

            <div class="col-md-6">
                <span class="info-label">Estado</span>
                <br />
                <span class="badge @(Model.Activo == true ? "bg-success" : "bg-danger")">
                    @(Model.Activo == true ? "Activa" : "Inactiva")
                </span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-delete').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Dar de baja especialidad?',
                    text: 'La especialidad quedará inactiva.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, dar de baja',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar especialidad?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, reactivar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}