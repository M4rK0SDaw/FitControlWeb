@model IEnumerable<FitControlWeb.Models.Entities.TipoSuscripcion>

@{
    ViewData["Title"] = "Tipos de suscripción";

    var tipos = Model?.ToList() ?? new List<FitControlWeb.Models.Entities.TipoSuscripcion>();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;   
    int pageSize = ViewBag.PageSize ?? 10;
    int totalTipos = ViewBag.TotalTipos ?? 0;

    int tiposActivos = tipos.Count(t => t.Activo == true);
    int tiposInactivos = tipos.Count(t => t.Activo != true);
    // decimal precioMedio = tipos.Any() ? tipos.Average(t => t.Precio) : 0;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Tipos de suscripción</h2>
            <p class="text-muted mb-0">Gestión de planes, precios y duración</p>
        </div>

        <a asp-action="Create" class="btn btn-orange">
            <i class="bi bi-plus-circle me-1"></i> Nuevo tipo
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Tipos encontrados</span>
                <p class="info-value mb-0">@totalTipos</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Activos en esta página</span>
                <p class="info-value mb-0">@tiposActivos</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Inactivos en esta página</span>
                <p class="info-value mb-0">@tiposInactivos</p>
            </div>
        </div>

        @* <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Precio medio página</span>
                <p class="info-value mb-0">@precioMedio.ToString("0.00") €</p>
            </div>
        </div> *@
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Nombre del plan..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="activo" class="form-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(ViewBag.Activo?.ToString() == "True")">Activos</option>
                    <option value="false" selected="@(ViewBag.Activo?.ToString() == "False")">Inactivos</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>

    @if (!tipos.Any())
    {
        <div class="alert alert-info">
            No hay tipos de suscripción con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Duración</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var t in tipos)
                    {
                        <tr>
                            <td class="fw-semibold"><strong>@t.Nombre</strong></td>

                            <td>@t.Precio.ToString("0.00") €</td>

                            <td>@t.DuracionDias días</td>

                            <td>
                                <span class="badge @(t.Activo == true ? "bg-success" : "bg-danger")">
                                    @(t.Activo == true ? "Activo" : "Inactivo")
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                           asp-route-id="@t.Id"
                                           class="btn btn-sm btn-outline-dark"
                                           title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@t.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (t.Activo == true)
                                    {
                                        <form asp-action="Desactivar"
                                              asp-route-id="@t.Id"
                                              method="post"
                                              class="d-inline form-desactivar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-desactivar"
                                                    title="Desactivar tipo">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activar"
                                              asp-route-id="@t.Id"
                                              method="post"
                                              class="d-inline form-activar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-activar"
                                                    title="Activar tipo">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">

                <span class="text-muted small">
                    Página @currentPage de @totalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@pageSize"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-activo="@ViewBag.Activo">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@totalPages"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-activo="@ViewBag.Activo">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-desactivar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Desactivar tipo de suscripción?',
                    text: 'Este tipo dejará de estar disponible para nuevas suscripciones.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, desactivar',
                    cancelButtonText: 'Volver'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        document.querySelectorAll('.btn-activar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Activar tipo de suscripción?',
                    text: 'Este tipo volverá a estar disponible para nuevas suscripciones.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, activar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}