@model FitControlWeb.ViewModels.SuscripcionEditViewModel
@using FitControlWeb.Models.Entities

@{
    ViewData["Title"] = "Editar suscripción";

    var tipos = ViewBag.TiposSuscripcionData as List<TipoSuscripcion>
        ?? new List<TipoSuscripcion>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Editar suscripción</h2>
            <p class="text-muted mb-0">Modificar cliente, tipo, fechas y estado</p>
        </div>

        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="info-box">
                    <h5 class="fw-bold mb-3">Datos de suscripción</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UsuarioId" class="form-label">Cliente</label>
                            <select asp-for="UsuarioId" asp-items="ViewBag.Usuarios" class="form-select"></select>
                            <span asp-validation-for="UsuarioId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TipoSuscripcionId" class="form-label">Tipo</label>

                            <select asp-for="TipoSuscripcionId" class="form-select" id="tipoSuscripcion">
                                @foreach (var tipo in tipos)
                                {
                                    <option value="@tipo.Id"
                                            data-duracion="@tipo.DuracionDias"
                                            data-precio="@tipo.Precio.ToString("0.00")"
                                            selected="@(tipo.Id == Model.TipoSuscripcionId)">
                                        @tipo.Nombre - @tipo.Precio.ToString("0.00") € - @tipo.DuracionDias días
                                    </option>
                                }
                            </select>

                            <span asp-validation-for="TipoSuscripcionId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaInicio" class="form-label">Fecha inicio</label>
                            <input asp-for="FechaInicio" type="date" class="form-control" id="fechaInicio" />
                            <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaFin" class="form-label">Fecha fin</label>                            
                            <input asp-for="FechaFin" type="date" class="form-control" id="fechaFin" readonly />
                            <span asp-validation-for="FechaFin" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Precio del tipo</label>
                            <input type="text" class="form-control" id="precioVisual" readonly />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="info-box">
                    <h5 class="fw-bold mb-3">Estado</h5>

                    <div class="form-check">
                        <input asp-for="Activa" class="form-check-input" />
                        <label asp-for="Activa" class="form-check-label">Suscripción activa</label>
                    </div>

                    <small class="text-muted d-block mt-3">                        
                        Si cambias el tipo o la fecha de inicio, la fecha fin se recalcula automáticamente.
                    </small>                    
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>

            <button type="submit" class="btn btn-orange">
                <i class="bi bi-save me-1"></i> Guardar cambios
            </button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function actualizarSuscripcion() {
            const tipoSelect = document.getElementById("tipoSuscripcion");
            const fechaInicioInput = document.getElementById("fechaInicio");
            const fechaFinInput = document.getElementById("fechaFin");
            const precioInput = document.getElementById("precioVisual");

            const selected = tipoSelect.options[tipoSelect.selectedIndex];

            const duracion = parseInt(selected?.dataset?.duracion || "0");
            const precio = selected?.dataset?.precio || "";

            precioInput.value = precio ? precio + " €" : "";

            if (!fechaInicioInput.value || duracion <= 0) {
                fechaFinInput.value = "";
                return;
            }

            const fecha = new Date(fechaInicioInput.value);
            fecha.setDate(fecha.getDate() + duracion);

            fechaFinInput.value = fecha.toISOString().split("T")[0];
        }

        document.getElementById("tipoSuscripcion").addEventListener("change", actualizarSuscripcion);
        document.getElementById("fechaInicio").addEventListener("change", actualizarSuscripcion);

        actualizarSuscripcion();
    </script>
}