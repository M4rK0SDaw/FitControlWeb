@model FitControlWeb.ViewModels.Suscripciones.SuscripcionIndexViewModel

@{
    ViewData["Title"] = "Suscripciones";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Suscripciones</h2>
            <p class="text-muted mb-0">Gestion de suscripciones de clientes</p>
        </div>

        <a asp-action="Create" class="btn btn-orange">
            <i class="bi bi-plus-circle me-1"></i> Nueva suscripcion
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Suscripciones encontradas</span>
                <p class="info-value mb-0">@Model.TotalSuscripciones</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Activas en pagina</span>
                <p class="info-value mb-0">@Model.ActivasPagina</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Inactivas en pagina</span>
                <p class="info-value mb-0">@Model.InactivasPagina</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Vencidas en pagina</span>
                <p class="info-value mb-0">@Model.VencidasPagina</p>
            </div>
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Cliente, email o tipo..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todas</option>
                    <option value="Activa" selected="@(Model.Estado == "Activa")">Activas</option>
                    <option value="Cancelada" selected="@(Model.Estado == "Cancelada")">Canceladas</option>
                    <option value="Vencida" selected="@(Model.Estado == "Vencida")">Vencidas</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>

        <br />
        <partial name="_ExportButtons" model="Model.ExportButtons" />
    </div>

    @if (!Model.Suscripciones.Any())
    {
        <div class="alert alert-info">
            No hay suscripciones con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Email</th>
                        <th>Tipo</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var suscripcion in Model.Suscripciones)
                    {
                        bool vencida = suscripcion.FechaFin < DateTime.Today;

                        <tr>
                            <td>
                                @(suscripcion.Usuario != null
                                    ? $"{suscripcion.Usuario.Nombre} {suscripcion.Usuario.Apellidos}"
                                    : "Usuario no disponible")
                            </td>
                            <td>@(suscripcion.Usuario?.Email ?? "Sin email")</td>
                            <td>@(suscripcion.TipoSuscripcion?.Nombre ?? "Sin tipo")</td>
                            <td>@suscripcion.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@suscripcion.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>@(suscripcion.TipoSuscripcion?.Precio.ToString("0.00") ?? "0.00") €</td>
                            <td>
                                @if (suscripcion.Activa == true && !vencida)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else if (suscripcion.Activa == true && vencida)
                                {
                                    <span class="badge bg-warning text-dark">Vencida</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelada</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                       asp-route-id="@suscripcion.Id"
                                       class="btn btn-sm btn-outline-dark"
                                       title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@suscripcion.Id"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (suscripcion.Usuario != null)
                                    {
                                        <a asp-controller="Usuarios"
                                           asp-action="Details"
                                           asp-route-id="@suscripcion.UsuarioId"
                                           class="btn btn-sm btn-outline-secondary"
                                           title="Ver cliente">
                                            <i class="bi bi-person"></i>
                                        </a>
                                    }

                                    @if (suscripcion.Activa == true)
                                    {
                                        <form asp-action="Cancelar"
                                              asp-route-id="@suscripcion.Id"
                                              method="post"
                                              class="d-inline form-cancelar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-cancelar"
                                                    title="Cancelar suscripcion">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivar"
                                              asp-route-id="@suscripcion.Id"
                                              method="post"
                                              class="d-inline form-reactivar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-reactivar"
                                                    title="Reactivar suscripcion">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                <span class="text-muted small">
                    Pagina @Model.CurrentPage de @Model.TotalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="1"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-estado="@Model.Estado">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-estado="@Model.Estado">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-estado="@Model.Estado">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-estado="@Model.Estado">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@Model.TotalPages"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-estado="@Model.Estado">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-cancelar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Cancelar suscripcion?',
                    text: 'La suscripcion quedara cancelada y dejara de estar activa.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Si, cancelar',
                    cancelButtonText: 'Volver'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar suscripcion?',
                    text: 'Solo se reactivara si el cliente no tiene otra suscripcion activa y no esta vencida.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Si, reactivar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}
