@model IEnumerable<FitControlWeb.Models.Entities.Suscripcion>
@using FitControlWeb.ViewModels.Shared

@{
    ViewData["Title"] = "Suscripciones";

    var suscripciones = Model?.ToList() ?? new List<FitControlWeb.Models.Entities.Suscripcion>();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalSuscripciones = ViewBag.TotalSuscripciones ?? 0;

    int activasPagina = suscripciones.Count(s => s.Activa == true);
    int inactivasPagina = suscripciones.Count(s => s.Activa != true);
    int vencidasPagina = suscripciones.Count(s => s.Activa == true && s.FechaFin < DateTime.Today);

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Suscripciones</h2>
            <p class="text-muted mb-0">Gestión de suscripciones de clientes</p>
        </div>

        <a asp-action="Create" class="btn btn-orange">
            <i class="bi bi-plus-circle me-1"></i> Nueva suscripción
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Suscripciones encontradas</span>
                <p class="info-value mb-0">@totalSuscripciones</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Activas en página</span>
                <p class="info-value mb-0">@activasPagina</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Inactivas en página</span>
                <p class="info-value mb-0">@inactivasPagina</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Vencidas en página</span>
                <p class="info-value mb-0">@vencidasPagina</p>
            </div>
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Cliente, email o tipo..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todas</option>
                    <option value="Activa" selected="@(ViewBag.Estado == "Activa")">Activas</option>
                    <option value="Cancelada" selected="@(ViewBag.Estado == "Cancelada")">Canceladas</option>
                    <option value="Vencida" selected="@(ViewBag.Estado == "Vencida")">Vencidas</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
        <br />

        @{
            var exportModel = new ExportButtonsViewModel
            {
                Controller = "Suscripciones",
                ExcelAction = "ExportExcel",
                CsvAction = "ExportCsv",
                PdfAction = "ExportPdf",
                RouteValues = new Dictionary<string, string?>
                {
                    { "search", ViewBag.Search?.ToString() },
                    { "estado", ViewBag.Estado?.ToString() }
                }
            };
        }

        <partial name="_ExportButtons" model="exportModel" />

    </div>

    @if (!suscripciones.Any())
    {
        <div class="alert alert-info">
            No hay suscripciones con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Email</th>
                        <th>Tipo</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var s in suscripciones)
                    {
                        bool vencida = s.FechaFin < DateTime.Today;

                        <tr>
                            <td>
                                @(s.Usuario != null
                                    ? $"{s.Usuario.Nombre} {s.Usuario.Apellidos}"
                                    : "Usuario no disponible")
                            </td>

                            <td>@(s.Usuario?.Email ?? "Sin email")</td>

                            <td>@(s.TipoSuscripcion?.Nombre ?? "Sin tipo")</td>

                            <td>@s.FechaInicio.ToString("dd/MM/yyyy")</td>

                            <td>@s.FechaFin.ToString("dd/MM/yyyy")</td>

                            <td>
                                @(s.TipoSuscripcion?.Precio.ToString("0.00") ?? "0.00") €
                            </td>

                            <td>
                                @if (s.Activa == true && !vencida)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else if (s.Activa == true && vencida)
                                {
                                    <span class="badge bg-warning text-dark">Vencida</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelada</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                           asp-route-id="@s.Id"
                                           class="btn btn-sm btn-outline-dark"
                                           title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@s.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (s.Usuario != null)
                                    {
                                        <a asp-controller="Usuarios"
                                               asp-action="Details"
                                               asp-route-id="@s.UsuarioId"
                                               class="btn btn-sm btn-outline-secondary"
                                               title="Ver cliente">
                                            <i class="bi bi-person"></i>
                                        </a>
                                    }

                                    @if (s.Activa == true)
                                    {
                                        <form asp-action="Cancelar"
                                              asp-route-id="@s.Id"
                                              method="post"
                                              class="d-inline form-cancelar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-cancelar"
                                                    title="Cancelar suscripción">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivar"
                                              asp-route-id="@s.Id"
                                              method="post"
                                              class="d-inline form-reactivar">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-reactivar"
                                                    title="Reactivar suscripción">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">

                <span class="text-muted small">
                    Página @currentPage de @totalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@pageSize"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-estado="@ViewBag.Estado">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@totalPages"
                                   asp-route-pageSize="@pageSize"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-cancelar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Cancelar suscripción?',
                    text: 'La suscripción quedará cancelada y dejará de estar activa.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, cancelar',
                    cancelButtonText: 'Volver'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        document.querySelectorAll('.btn-reactivar').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Reactivar suscripción?',
                    text: 'Solo se reactivará si el cliente no tiene otra suscripción activa y no está vencida.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, reactivar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}