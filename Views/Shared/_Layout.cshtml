<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitControl Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FitControlWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
@{
    string? usuarioIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    string? fotoUsuarioUrl = null;

    if (!string.IsNullOrWhiteSpace(usuarioIdClaim))
    {
        var extensiones = new[] { ".jpg", ".jpeg", ".png", ".webp" };

        foreach (var ext in extensiones)
        {
            var rutaFisica = System.IO.Path.Combine(
                Directory.GetCurrentDirectory(),
                "wwwroot",
                "uploads",
                "usuarios",
                $"usuario-{usuarioIdClaim}{ext}"
            );

            if (System.IO.File.Exists(rutaFisica))
            {
                fotoUsuarioUrl = $"/uploads/usuarios/usuario-{usuarioIdClaim}{ext}";
                break;
            }
        }
    }

    var nombreCompleto = User.FindFirst("NombreCompleto")?.Value ?? "Usuario";
    var rolUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Usuario";
    var inicialUsuario = !string.IsNullOrWhiteSpace(nombreCompleto)
        ? nombreCompleto.Substring(0, 1).ToUpper()
        : "U";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string IsActive(string controller, string? action = null)
    {
        var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatches = string.IsNullOrWhiteSpace(action) ||
            string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return controllerMatches && actionMatches ? "active" : "";
    }
}

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="app-shell" id="appShell">
            <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

            <aside class="sidebar" id="appSidebar" aria-label="Menu principal">
                <div class="sidebar-brand">
                    <a asp-controller="Home" asp-action="Index" class="brand-link" aria-label="FitControl Web">
                        <span class="brand-mark"><i class="bi bi-activity"></i></span>
                        <span class="brand-text"><span>FIT</span><strong>CONTROL</strong></span>
                    </a>

                    <button class="sidebar-icon-btn d-lg-none"
                            type="button"
                            id="closeMobileSidebar"
                            aria-label="Cerrar menu">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="sidebar-profile">
                    <div class="user-avatar sidebar-avatar">
                        @if (!string.IsNullOrWhiteSpace(fotoUsuarioUrl))
                        {
                            <img src="@fotoUsuarioUrl"
                                 alt="Foto de perfil"
                                 class="user-avatar-img" />
                        }
                        else
                        {
                            @inicialUsuario
                        }
                    </div>

                    <div class="sidebar-profile-text">
                        <strong>@nombreCompleto</strong>
                        <span>@rolUsuario</span>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="sidebar-link @IsActive("Dashboard")" title="Dashboard">
                            <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                        </a>

                        <a asp-controller="Usuarios" asp-action="Index" class="sidebar-link @IsActive("Usuarios")" title="Usuarios">
                            <i class="bi bi-people"></i><span>Usuarios</span>
                        </a>

                        <a asp-controller="Clases" asp-action="Index" class="sidebar-link @IsActive("Clases")" title="Clases">
                            <i class="bi bi-calendar2-week"></i><span>Clases</span>
                        </a>

                        <a asp-controller="Reservas" asp-action="Index" class="sidebar-link @IsActive("Reservas")" title="Reservas">
                            <i class="bi bi-calendar-check"></i><span>Reservas</span>
                        </a>

                        <a asp-controller="Suscripciones" asp-action="Index" class="sidebar-link @IsActive("Suscripciones")" title="Suscripciones">
                            <i class="bi bi-stars"></i><span>Suscripciones</span>
                        </a>

                        <a asp-controller="Especialidades" asp-action="Index" class="sidebar-link @IsActive("Especialidades")" title="Especialidades">
                            <i class="bi bi-lightning-charge"></i><span>Especialidades</span>
                        </a>

                        <a asp-controller="TipoSuscripciones" asp-action="Index" class="sidebar-link @IsActive("TipoSuscripciones")" title="Tipos de suscripcion">
                            <i class="bi bi-tags"></i><span>Tipos de suscripcion</span>
                        </a>

                        <a asp-controller="MetodoPagos" asp-action="Index" class="sidebar-link @IsActive("MetodoPagos")" title="Metodos de pago">
                            <i class="bi bi-credit-card-2-front"></i><span>Metodos de pago</span>
                        </a>

                        <a asp-controller="Facturas" asp-action="Index" class="sidebar-link @IsActive("Facturas")" title="Facturas">
                            <i class="bi bi-receipt"></i><span>Facturas</span>
                        </a>
                    }

                    @if (User.IsInRole("Cliente"))
                    {
                        <a asp-controller="ClienteDashboard" asp-action="Index" class="sidebar-link @IsActive("ClienteDashboard", "Index")" title="Mi panel">
                            <i class="bi bi-house-heart"></i><span>Mi panel</span>
                        </a>

                        <a asp-controller="Clases" asp-action="Index" class="sidebar-link @IsActive("Clases")" title="Clases disponibles">
                            <i class="bi bi-calendar2-plus"></i><span>Clases disponibles</span>
                        </a>

                        <a asp-controller="Reservas" asp-action="MisReservas" class="sidebar-link @IsActive("Reservas", "MisReservas")" title="Mis reservas">
                            <i class="bi bi-bookmark-check"></i><span>Mis reservas</span>
                        </a>

                        <a asp-controller="ClienteDashboard" asp-action="MisFacturas" class="sidebar-link @IsActive("ClienteDashboard", "MisFacturas")" title="Mis facturas">
                            <i class="bi bi-receipt-cutoff"></i><span>Mis facturas</span>
                        </a>

                        <a asp-controller="Mensajes" asp-action="Index" class="sidebar-link @IsActive("Mensajes")" title="Mensajes">
                            <i class="bi bi-chat-dots"></i>
                            <span>Mensajes</span>
                            <span id="chatSidebarBadge" class="nav-badge d-none">0</span>
                        </a>
                    }

                    @if (User.IsInRole("Entrenador"))
                    {
                        <a asp-controller="EntrenadorDashboard" asp-action="Index" class="sidebar-link @IsActive("EntrenadorDashboard")" title="Mi panel">
                            <i class="bi bi-clipboard2-pulse"></i><span>Mi panel</span>
                        </a>

                        @* <a asp-controller="EntrenadorDashboard" asp-action="Perfil" class="sidebar-link @IsActive("EntrenadorDashboard", "Perfil")" title="Mi perfil">
                            <i class="bi bi-person-badge"></i><span>Mi perfil</span>
                        </a>
 *@
                        <a asp-controller="Clases" asp-action="Index" class="sidebar-link @IsActive("Clases")" title="Mis clases">
                            <i class="bi bi-calendar2-week"></i><span>Mis clases</span>
                        </a>

                        <a asp-controller="Reservas" asp-action="Index" class="sidebar-link @IsActive("Reservas")" title="Reservas">
                            <i class="bi bi-person-lines-fill"></i><span>Reservas</span>
                        </a>

                        <a asp-controller="Mensajes" asp-action="Index" class="sidebar-link @IsActive("Mensajes")" title="Mensajes">
                            <i class="bi bi-chat-dots"></i>
                            <span>Mensajes</span>
                            <span id="chatSidebarBadge" class="nav-badge d-none">0</span>
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="sidebar-footer-chip">
                        <i class="bi bi-shield-check"></i>
                        <span>FitControl Web</span>
                    </div>
                    <small>Proyecto DAW 2026</small>
                </div>
            </aside>

            <div class="main-area">
                <header class="topbar">
                    <div class="topbar-left">
                        <button class="topbar-icon-btn d-lg-none"
                                type="button"
                                id="openMobileSidebar"
                                aria-label="Abrir menu">
                            <i class="bi bi-list"></i>
                        </button>

                        <button class="topbar-icon-btn d-none d-lg-inline-flex"
                                type="button"
                                id="toggleSidebar"
                                aria-label="Contraer menu">
                            <i class="bi bi-layout-sidebar-inset"></i>
                        </button>

                        <div>
                            <h5 class="mb-0">@ViewData["Title"]</h5>
                            <small class="text-muted">Panel de gestion del gimnasio</small>
                        </div>
                    </div>

                    <div class="topbar-actions">
                        @if (User.IsInRole("Cliente"))
                        {
                            <a asp-controller="ClienteDashboard" asp-action="ContratarSuscripcion" class="quick-pill">
                                <i class="bi bi-stars"></i><span>Plan</span>
                            </a>
                        }

                        <button type="button"
                                class="quick-pill quick-theme"
                                id="themeToggle"
                                aria-label="Cambiar tema">
                            <i class="bi bi-moon-stars"></i><span>Tema</span>
                        </button>

                        <button type="button"
                                class="quick-pill"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#notificationsOffcanvas"
                                aria-controls="notificationsOffcanvas">
                            <i class="bi bi-bell"></i>
                            <span>Notificaciones</span>
                        </button>

                        <div class="user-box">
                            <div class="user-avatar">
                                @if (!string.IsNullOrWhiteSpace(fotoUsuarioUrl))
                                {
                                    <img src="@fotoUsuarioUrl"
                                         alt="Foto de perfil"
                                         class="user-avatar-img" />
                                }
                                else
                                {
                                    @inicialUsuario
                                }
                            </div>

                            <div class="user-info">
                                <span>@nombreCompleto</span>
                                <small>@rolUsuario</small>
                            </div>

                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-logout" type="submit" title="Salir">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Salir</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </header>

                <main class="content-area">
                    <partial name="_Alerts" />
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main>
            <partial name="_Alerts" />
            @RenderBody()
        </main>
    }

    @if (User.Identity?.IsAuthenticated == true &&
        (User.IsInRole("Cliente") || User.IsInRole("Entrenador")))
    {
        <button class="btn btn-orange chat-float-btn position-relative"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#chatOffcanvas"
                aria-controls="chatOffcanvas"
                id="btnAbrirChat">
            <i class="bi bi-chat-dots-fill"></i>

            <span id="chatUnreadBadge"
                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                0
            </span>
        </button>

        <div class="offcanvas offcanvas-end chat-offcanvas"
             tabindex="-1"
             id="chatOffcanvas"
             aria-labelledby="chatOffcanvasLabel">

            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" id="chatOffcanvasLabel">
                    <i class="bi bi-chat-heart me-2"></i>FitControl Chat
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="offcanvas"
                        aria-label="Cerrar"></button>
            </div>

            <div class="offcanvas-body" id="chatContainer">
                <div class="text-muted">
                    Cargando conversaciones...
                </div>
            </div>
        </div>
    }

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="offcanvas offcanvas-end notifications-offcanvas" tabindex="-1" id="notificationsOffcanvas" aria-labelledby="notificationsOffcanvasLabel">
            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" id="notificationsOffcanvasLabel">
                    <i class="bi bi-bell-fill me-2"></i>Notificaciones temporales
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
                <div class="d-flex justify-content-end mb-3">
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearNotificationsBtn">
                        Limpiar
                    </button>
                </div>
                <div id="notificationsList" class="d-grid gap-2"></div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        let chatPopupUsuarioActual = null;
        let chatPopupConversacionActual = null;

        function escapeHtml(value) {
            return (value ?? '')
                .toString()
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function appendChatMessage(message) {
            const chatBox = document.getElementById('chatBoxPopup');
            if (!chatBox || !message) return;

            const emptyState = chatBox.querySelector('.alert');
            if (emptyState) {
                emptyState.remove();
            }

            const wrapper = document.createElement('div');
            wrapper.className = `chat-message ${message.esMio ? 'mine' : 'other'}`;
            wrapper.innerHTML = `
                <div class="fw-semibold small mb-1">${escapeHtml(message.remitenteNombre)}</div>
                <div>${escapeHtml(message.contenido)}</div>
                <div class="chat-time mt-1">
                    ${escapeHtml(message.fechaTexto)}
                    ${message.esMio && message.leido ? '<span> · leido</span>' : ''}
                </div>
            `;

            chatBox.appendChild(wrapper);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function marcarConversacionLeida(conversacionId) {
            const form = document.getElementById('chatEnviarForm');
            const token = form?.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!conversacionId || !token) return;

            try {
                await fetch('/Mensajes/MarcarLeidosAjax', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: `__RequestVerificationToken=${encodeURIComponent(token)}&conversacionId=${encodeURIComponent(conversacionId)}`
                });
            } catch {
                // Si falla el marcado, no interrumpimos el chat.
            }
        }

        async function cargarChatPanel() {
            const container = document.getElementById('chatContainer');

            if (!container) return;

            container.innerHTML = '<div class="text-muted">Cargando conversaciones...</div>';

            const response = await fetch('/Mensajes/ChatPanel');

            if (!response.ok) {
                container.innerHTML = '<div class="alert alert-danger">Error al cargar el chat.</div>';
                return;
            }

            container.innerHTML = await response.text();
            inicializarChatEventos();
        }

        async function cargarConversacion(usuarioId) {
            const container = document.getElementById('chatContainer');

            container.innerHTML = '<div class="text-muted">Cargando conversacion...</div>';

            const response = await fetch(`/Mensajes/ChatConversacion?usuarioId=${usuarioId}`);

            if (!response.ok) {
                container.innerHTML = '<div class="alert alert-danger">No se pudo cargar la conversacion.</div>';
                return;
            }

            container.innerHTML = await response.text();

            const chatBox = document.getElementById('chatBoxPopup');
            if (chatBox) {
                chatBox.scrollTop = chatBox.scrollHeight;
            }

            inicializarChatEventos();
        }

        function inicializarChatEventos() {
            chatPopupUsuarioActual = null;
            chatPopupConversacionActual = null;

            document.querySelectorAll('.chat-conversation-item').forEach(button => {
                button.addEventListener('click', function () {
                    const userId = this.dataset.userId;
                    cargarConversacion(userId);
                });
            });

            const btnVolver = document.getElementById('btnVolverChat');
            if (btnVolver) {
                btnVolver.addEventListener('click', function () {
                    cargarChatPanel();
                });
            }

            const form = document.getElementById('chatEnviarForm');
            if (form) {
                const currentUserInput = document.getElementById('chatPopupOtroUsuarioId');
                const currentConversationInput = document.getElementById('chatPopupConversacionId');
                if (currentUserInput?.value) {
                    chatPopupUsuarioActual = currentUserInput.value.toString();
                }
                if (currentConversationInput?.value) {
                    chatPopupConversacionActual = currentConversationInput.value.toString();
                }

                form.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const formData = new FormData(form);

                    const response = await fetch('/Mensajes/EnviarAjax', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'No se pudo enviar el mensaje.'
                        });

                        return;
                    }

                    const data = await response.json();
                    if (data.success) {
                        const textarea = form.querySelector('textarea[name="contenido"]');
                        if (data.message) {
                            appendChatMessage(data.message);
                        }

                        if (textarea) {
                            textarea.value = '';
                            textarea.focus();
                        }

                        actualizarContadorMensajes();
                    }
                });
            }
        }

        const chatOffcanvas = document.getElementById('chatOffcanvas');

        if (chatOffcanvas) {
            chatOffcanvas.addEventListener('shown.bs.offcanvas', async function () {
                await cargarChatPanel();
                actualizarContadorMensajes();
            });
        }

        async function actualizarContadorMensajes() {
            const badgeFloat = document.getElementById('chatUnreadBadge');
            const badgeSidebar = document.getElementById('chatSidebarBadge');

            if (!badgeFloat && !badgeSidebar) return;

            try {
                const response = await fetch('/Mensajes/NoLeidos');

                if (!response.ok) return;

                const data = await response.json();
                const total = data.total ?? 0;

                [badgeFloat, badgeSidebar].forEach(badge => {
                    if (!badge) return;

                    if (total > 0) {
                        badge.textContent = total > 99 ? '99+' : total;
                        badge.classList.remove('d-none');
                    } else {
                        badge.textContent = '0';
                        badge.classList.add('d-none');
                    }
                });
            } catch {
                // Evita interrumpir la navegacion si el contador no responde.
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            actualizarContadorMensajes();
            setInterval(actualizarContadorMensajes, 15000);

            const key = 'fitcontrol-temp-notifications';
            const list = document.getElementById('notificationsList');
            const clearBtn = document.getElementById('clearNotificationsBtn');

            function leerNotificaciones() {
                try {
                    return JSON.parse(sessionStorage.getItem(key) || '[]');
                } catch {
                    return [];
                }
            }

            function guardarNotificaciones(items) {
                sessionStorage.setItem(key, JSON.stringify(items.slice(-50)));
            }

            function pintarNotificaciones() {
                if (!list) return;
                const items = leerNotificaciones().reverse();

                if (items.length === 0) {
                    list.innerHTML = '<div class="text-muted">No hay notificaciones temporales.</div>';
                    return;
                }

                list.innerHTML = items.map(item => `
                    <div class="notification-item border rounded-3 p-3">
                        <div class="fw-bold text-capitalize">${item.title ?? item.type ?? 'Aviso'}</div>
                        <div>${item.text ?? ''}</div>
                        <small class="text-muted">${new Date(item.time).toLocaleString()}</small>
                    </div>
                `).join('');
            }

            document.addEventListener('fitcontrol:notify', (event) => {
                const items = leerNotificaciones();
                items.push(event.detail);
                guardarNotificaciones(items);
                pintarNotificaciones();
            });

            clearBtn?.addEventListener('click', () => {
                guardarNotificaciones([]);
                pintarNotificaciones();
            });

            pintarNotificaciones();

            if (window.signalR) {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub')
                    .withAutomaticReconnect()
                    .build();

                connection.on('chat:new-message', (payload) => {
                    actualizarContadorMensajes();

                    document.dispatchEvent(new CustomEvent('fitcontrol:notify', {
                        detail: {
                            type: 'info',
                            title: 'Mensaje',
                            text: 'Has recibido un nuevo mensaje.',
                            time: new Date().toISOString()
                        }
                    }));

                    const chatPanelAbierto = document.getElementById('chatOffcanvas');
                    if (chatPanelAbierto?.classList.contains('show')) {
                        const remitenteId = payload?.remitenteId?.toString();
                        const conversacionId = payload?.conversacionId?.toString();

                        if (chatPopupUsuarioActual && remitenteId && chatPopupUsuarioActual === remitenteId &&
                            chatPopupConversacionActual && conversacionId && chatPopupConversacionActual === conversacionId) {
                            appendChatMessage({
                                contenido: payload?.contenido ?? '',
                                fechaTexto: payload?.fechaTexto ?? '',
                                esMio: false,
                                remitenteNombre: payload?.remitenteNombre ?? 'Usuario',
                                leido: payload?.leido === true
                            });
                            marcarConversacionLeida(conversacionId);
                        } else {
                            cargarChatPanel();
                        }
                    }
                });

                connection.start().catch(() => {
                    // Si falla el realtime, el chat sigue funcionando por polling.
                });
            }
        });
    </script>
</body>
</html>
