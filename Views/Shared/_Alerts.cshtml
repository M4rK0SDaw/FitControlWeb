@{
    var alerts = new[]
    {
        new { Key = "Success", Icon = "success", Title = "Correcto" },
        new { Key = "Error", Icon = "error", Title = "Error" },
        new { Key = "Warning", Icon = "warning", Title = "Atencion" },
        new { Key = "Info", Icon = "info", Title = "Informacion" }
    };
}

@foreach (var alert in alerts)
{
    if (TempData[alert.Key] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: '@alert.Icon',
                    title: '@alert.Title',
                    text: '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData[alert.Key]?.ToString() ?? ""))',
                    showConfirmButton: false,
                    timer: 3200,
                    timerProgressBar: true,
                    customClass: {
                        popup: 'fit-toast'
                    }
                });

                const entry = {
                    type: '@alert.Icon',
                    title: '@alert.Title',
                    text: '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData[alert.Key]?.ToString() ?? ""))',
                    time: new Date().toISOString()
                };
                document.dispatchEvent(new CustomEvent('fitcontrol:notify', { detail: entry }));
            });
        </script>
    }
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const summaries = Array.from(document.querySelectorAll('[data-fit-validation-toast="true"]'));

        summaries.forEach(summary => {
            const messages = Array.from(summary.querySelectorAll('li, span'))
                .map(node => node.textContent?.trim())
                .filter(Boolean);

            if (!messages.length) {
                return;
            }

            summary.classList.add('d-none');

            const uniqueMessages = [...new Set(messages)];
            const html = uniqueMessages.length === 1
                ? `<p class="mb-0">${uniqueMessages[0]}</p>`
                : `<ul class="mb-0 text-start ps-3">${uniqueMessages.map(message => `<li>${message}</li>`).join('')}</ul>`;

            Swal.fire({
                icon: 'error',
                title: 'Revisa el formulario',
                html,
                confirmButtonText: 'Entendido',
                customClass: {
                    popup: 'fit-toast fit-form-modal'
                }
            });
        });
    });
</script>
