@model FitControlWeb.Models.Entities.Conversacion

@{
    ViewData["Title"] = "Conversación";

    int usuarioActualId = ViewBag.UsuarioActualId;
    var otroUsuario = ViewBag.OtroUsuario as FitControlWeb.Models.Entities.Usuario;
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />

    <style>
        .chat-box {
            max-height: 520px;
            overflow-y: auto;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 16px;
            border: 1px solid #e5e7eb;
        }

        .chat-message {
            max-width: 75%;
            padding: .75rem 1rem;
            border-radius: 16px;
            margin-bottom: .75rem;
        }

            .chat-message.mine {
                margin-left: auto;
                background: #ff7a00;
                color: white;
            }

            .chat-message.other {
                margin-right: auto;
                background: white;
                border: 1px solid #dee2e6;
            }

        .chat-time {
            font-size: .75rem;
            opacity: .75;
        }
    </style>
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Conversación</h2>
            <p class="text-muted mb-0">
                Con @otroUsuario?.Nombre @otroUsuario?.Apellidos
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="chat-box mb-4" id="chatBox">
        @if (!Model.Mensajes.Any())
        {
            <div class="alert alert-info mb-0">
                No hay mensajes todavía. Escribe el primero.
            </div>
        }
        else
        {
            foreach (var m in Model.Mensajes.OrderBy(m => m.FechaEnvio))
            {
                <partial name="_MensajeBurbuja" model="m" />
            }
        }
    </div>

    <form asp-action="Enviar" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="conversacionId" value="@Model.Id" />

        <div class="row g-2">
            <div class="col-md-10">
                <textarea name="contenido"
                          class="form-control"
                          rows="3"
                          maxlength="1000"
                          required
                          placeholder="Escribe tu mensaje..."></textarea>
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-orange">
                    <i class="bi bi-send"></i> Enviar
                </button>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <script>
        const chatBox = document.getElementById('chatBox');

        if (chatBox) {
            chatBox.scrollTop = chatBox.scrollHeight; 

        }
    </script>
}