@model FitControlWeb.ViewModels.Dashboard.EntrenadorPerfilViewModel
@{
    ViewData["Title"] = "Mi perfil";

    var extensiones = new[] { ".jpg", ".jpeg", ".png", ".webp" };
    string? fotoUrl = null;

    foreach (var ext in extensiones)
    {
        var rutaFisica = System.IO.Path.Combine(
            Directory.GetCurrentDirectory(),
            "wwwroot",
            "uploads",
            "usuarios",
            $"usuario-{Model.Id}{ext}"
        );

        if (System.IO.File.Exists(rutaFisica))
        {
            fotoUrl = $"/uploads/usuarios/usuario-{Model.Id}{ext}";
            break;
        }
    }

    fotoUrl ??= "/img/default-user.png";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Mi perfil</h2>
            <p class="text-muted mb-0">Gestiona tus datos personales como entrenador.</p>
        </div>

        <a asp-controller="EntrenadorDashboard"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <form asp-action="Perfil"
          asp-controller="EntrenadorDashboard"
          method="post"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="info-box h-100 text-center">

                    <img id="previewFoto"
                         src="@fotoUrl"
                         alt="Foto de perfil"
                         class="rounded-circle mb-3 shadow-sm"
                         style="width: 150px; height: 150px; object-fit: cover;" />

                    <h5 class="fw-bold mb-1">@Model.Nombre @Model.Apellidos</h5>
                    <p class="text-muted mb-3">@Model.Email</p>

                    <label for="Foto" class="form-label fw-semibold">Cambiar foto</label>

                    <input type="file"
                           name="Foto"
                           id="Foto"
                           class="form-control"
                           accept=".jpg,.jpeg,.png,.webp" />

                    <small class="text-muted d-block mt-2">
                        JPG, PNG o WEBP. Máximo 5MB.
                    </small>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="info-box h-100">
                    <h5 class="fw-bold mb-3">Datos personales</h5>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Apellidos" class="form-label"></label>
                            <input asp-for="Apellidos" class="form-control" />
                            <span asp-validation-for="Apellidos" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" readonly />
                            <small class="text-muted">
                                El email no se puede cambiar desde el perfil.
                            </small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label"></label>
                            <input asp-for="Telefono" class="form-control" placeholder="600 000 000" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="NuevaPassword" class="form-label">Nueva contraseña</label>
                            <input asp-for="NuevaPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Déjalo vacío si no quieres cambiarla" />
                            <span asp-validation-for="NuevaPassword" class="text-danger small"></span>

                            <p class="text-muted mb-0 mt-1">
                                Si cambias tu contraseña, tendrás que usar la nueva contraseña en el próximo inicio de sesión.
                            </p>
                        </div>

                    </div>
                </div>
            </div>

            <!-- PREFERENCIAS VISUALES ABAJO A LA IZQUIERDA -->
            <div class="col-lg-4">
                <div class="info-box">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-palette me-2"></i>Preferencias visuales
                    </h5>

                    <div class="row g-3">

                        <div class="col-12">
                            <label for="preferenciaTema" class="form-label">Tema</label>
                            <select id="preferenciaTema" class="form-select">
                                <option value="light">Claro</option>
                                <option value="dark">Oscuro</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label for="preferenciaFondo" class="form-label">Fondo</label>
                            <select id="preferenciaFondo" class="form-select">
                                <option value="soft">Suave</option>
                                <option value="clean">Limpio</option>
                                <option value="contrast">Contraste</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label for="preferenciaColor" class="form-label">Color principal</label>
                            <input id="preferenciaColor"
                                   type="color"
                                   class="form-control form-control-color"
                                   value="#ff7a00" />
                        </div>

                        <div class="col-12">
                            <label for="preferenciaFuente" class="form-label">Tamaño de fuente</label>
                            <select id="preferenciaFuente" class="form-select">
                                <option value="0.95">Compacta</option>
                                <option value="1">Normal</option>
                                <option value="1.08">Grande</option>
                            </select>
                        </div>

                    </div>

                    <div class="d-flex justify-content-end gap-2 flex-wrap mt-3">
                        <button type="button" class="btn btn-outline-secondary" id="btnResetPreferencias">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Restablecer
                        </button>

                        <button type="button" class="btn btn-orange" id="btnGuardarPreferencias">
                            <i class="bi bi-check2-circle me-1"></i> Aplicar
                        </button>
                    </div>
                </div>
            </div>

        </div>

