        <div class="d-flex justify-content-end gap-2 mt-4">
            <a asp-controller="EntrenadorDashboard"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Cancelar
            </a>

            <button type="submit" class="btn btn-orange">
                <i class="bi bi-save me-1"></i> Guardar cambios
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const inputFoto = document.getElementById('Foto');
        const previewFoto = document.getElementById('previewFoto');

        inputFoto.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;

            const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];

            if (!allowedTypes.includes(file.type)) {
                this.value = '';
                Swal.fire({ icon: 'error', title: 'Formato no valido', text: 'Usa JPG, PNG o WEBP.' });
                return;
            }

            if (file.size > 5 * 1024 * 1024) {
                this.value = '';
                Swal.fire({ icon: 'error', title: 'Imagen demasiado grande', text: 'La imagen no puede superar los 5MB.' });
                return;
            }

            previewFoto.src = URL.createObjectURL(file);
        });

        function setCookie(name, value, days) {
            const date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            document.cookie = `${name}=${value}; expires=${date.toUTCString()}; path=/; SameSite=Lax`;
        }

        function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) {
                return parts.pop().split(';').shift();
            }
            return null;
        }

        const tema = document.getElementById('preferenciaTema');
        const fondo = document.getElementById('preferenciaFondo');
        const color = document.getElementById('preferenciaColor');
        const fuente = document.getElementById('preferenciaFuente');

        function leerPreferencias() {
            return {
                theme: getCookie('fitcontrol-theme') || 'light',
                background: getCookie('fitcontrol-background') || 'soft',
                accent: getCookie('fitcontrol-accent') || '#ff7a00',
                fontScale: getCookie('fitcontrol-font-scale') || '1'
            };
        }

        function guardarPreferencias(preferences) {
            setCookie('fitcontrol-theme', preferences.theme, 3650);
            setCookie('fitcontrol-accent', preferences.accent, 3650);
            setCookie('fitcontrol-background', preferences.background, 3650);
            setCookie('fitcontrol-font-scale', preferences.fontScale, 3650);

            document.body.classList.toggle('dark-mode', preferences.theme === 'dark');
            document.dispatchEvent(new CustomEvent('fitcontrol:preferences-changed', { detail: preferences }));
        }

        function cargarPreferenciasEnFormulario() {
            const preferences = leerPreferencias();
            tema.value = preferences.theme;
            fondo.value = preferences.background;
            color.value = preferences.accent;
            fuente.value = preferences.fontScale;
        }

        cargarPreferenciasEnFormulario();

        document.getElementById('btnGuardarPreferencias').addEventListener('click', function () {
            const preferences = {
                theme: tema.value,
                background: fondo.value,
                accent: color.value,
                fontScale: fuente.value
            };

            guardarPreferencias(preferences);

            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: 'Preferencias aplicadas',
                showConfirmButton: false,
                timer: 2200,
                timerProgressBar: true
            });
        });

        document.getElementById('btnResetPreferencias').addEventListener('click', function () {
            guardarPreferencias({
                theme: 'light',
                background: 'soft',
                accent: '#ff7a00',
                fontScale: '1'
            });

            cargarPreferenciasEnFormulario();
        });
    </script>
}
