@model FitControlWeb.ViewModels.Dashboard.ClienteContratarSuscripcionViewModel

@{
    ViewData["Title"] = "Contratar suscripcion";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />

    <style>
        .subscription-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.5fr) minmax(260px, .9fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .subscription-note {
            border: 1px solid #ffe2bf;
            background: linear-gradient(135deg, #fff8f1 0%, #ffffff 100%);
            border-radius: 18px;
            padding: 20px;
        }

        .subscription-card {
            position: relative;
            height: 100%;
            min-height: 220px;
            padding: 1.5rem;
            border: 2px solid #e5e7eb;
            border-radius: 20px;
            background: #ffffff;
            cursor: pointer;
            transition: all .18s ease-in-out;
            user-select: none;
        }

        .subscription-card:hover {
            border-color: #ff7a00;
            box-shadow: 0 8px 18px rgba(0, 0, 0, .08);
        }

        .subscription-card.selected {
            border: 4px solid #ff7a00 !important;
            background: linear-gradient(135deg, #fff3e6 0%, #ffffff 100%);
            box-shadow: 0 0 0 5px rgba(255, 122, 0, .20), 0 16px 35px rgba(255, 122, 0, .25);
            transform: translateY(-4px);
        }

        .subscription-card.selected .subscription-title,
        .subscription-card.selected .subscription-price-main {
            color: #ff7a00;
        }

        .subscription-card.selected::before {
            content: "Seleccionado";
            position: absolute;
            top: 14px;
            right: 14px;
            background: #ff7a00;
            color: #fff;
            font-size: .7rem;
            font-weight: 800;
            padding: 5px 10px;
            border-radius: 999px;
        }

        .subscription-title {
            display: block;
            font-size: 1.25rem;
            font-weight: 800;
            padding-right: 110px;
        }

        .subscription-duration,
        .subscription-meta {
            margin-top: .75rem;
            color: #6c757d;
            font-size: .95rem;
        }

        .subscription-price {
            margin-top: 1.25rem;
        }

        .subscription-price-main {
            font-size: 2rem;
            font-weight: 900;
            color: #212529;
            line-height: 1;
        }

        .subscription-icon {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f3f5;
            color: #adb5bd;
            font-size: 1.4rem;
            margin-bottom: 1rem;
            transition: all .18s ease-in-out;
        }

        .subscription-card.selected .subscription-icon {
            background: #ff7a00;
            color: #fff;
        }

        .subscription-radio-dot {
            position: absolute;
            bottom: 16px;
            right: 16px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            border: 2px solid #ced4da;
            background: #fff;
            transition: all .18s ease-in-out;
        }

        .subscription-card.selected .subscription-radio-dot {
            border-color: #ff7a00;
            background: #ff7a00;
        }

        .subscription-card.selected .subscription-radio-dot::after {
            content: "✓";
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: .95rem;
            font-weight: 900;
        }

        .checkout-actions {
            position: sticky;
            bottom: 12px;
            z-index: 4;
            margin-top: 24px;
            padding: 14px 16px;
            background: rgba(255, 255, 255, .94);
            border: 1px solid #eceff3;
            border-radius: 18px;
            backdrop-filter: blur(6px);
        }

        @@media (max-width: 991.98px) {
            .subscription-hero {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .subscription-title {
                padding-right: 0;
            }

            .subscription-card {
                min-height: 0;
            }

            .subscription-card.selected::before {
                position: static;
                display: inline-block;
                margin-bottom: .75rem;
            }

            .checkout-actions .btn {
                width: 100%;
            }
        }
    </style>
}

<div class="page-card">
    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Contratar suscripcion</h2>
            <p class="text-muted mb-0">Elige tu plan y te llevamos directamente al pago seguro.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="subscription-hero">
        <div class="subscription-note">
            <h5 class="fw-bold mb-2">Como funciona</h5>
            <p class="text-muted mb-0">
                No se crea ninguna factura pendiente antes del cobro. Primero eliges el plan, pagas en Stripe y,
                cuando el pago vuelve confirmado, el sistema genera la suscripcion, la factura pagada y el registro del pago.
            </p>
        </div>

        <div class="info-box">
            <span class="info-label">Resumen</span>
            <p class="mb-2 fw-semibold">Pago inmediato y activacion automatica</p>
            <ul class="mb-0 ps-3 text-muted">
                <li>Sin facturas pendientes falsas</li>
                <li>Alta directa tras pago correcto</li>
                <li>Acceso al detalle de factura al volver</li>
            </ul>
        </div>
    </div>

    @if (Model.TieneSuscripcionActiva)
    {
        <div class="alert alert-warning">
            Ya tienes una suscripcion activa: <strong>@Model.NombreSuscripcionActiva</strong>.
            Finaliza el @Model.FechaFinSuscripcionActiva?.ToString("dd/MM/yyyy") antes de contratar otra.
        </div>
    }

    <form asp-action="ContratarSuscripcion" method="post" id="formContratarSuscripcion">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 d-none" data-fit-validation-toast="true"></div>

        <input type="hidden"
               name="TipoSuscripcionId"
               id="TipoSuscripcionId"
               value="@Model.TipoSuscripcionId" />

        <div class="row g-3">
            @foreach (var tipo in Model.TiposDisponibles)
            {
                var isSelected = Model.TipoSuscripcionId == tipo.Id;
                var iva = Math.Round(tipo.Precio * 0.21m, 2, MidpointRounding.AwayFromZero);
                var totalConIva = tipo.Precio + iva;

                <div class="col-12 col-md-6 col-xl-4">
                    <div class="subscription-card @(isSelected ? "selected" : "")"
                         data-tipo-id="@tipo.Id"
                         role="button"
                         tabindex="0"
                         style="@(Model.TieneSuscripcionActiva ? "opacity:.65;cursor:not-allowed;" : "")">

                        <div class="subscription-icon">
                            <i class="bi bi-stars"></i>
                        </div>

                        <strong class="subscription-title">@tipo.Nombre</strong>

                        <div class="subscription-duration">
                            <i class="bi bi-calendar-check me-1"></i>
                            Duracion: @tipo.DuracionDias dias
                        </div>

                        <div class="subscription-meta">
                            Acceso completo durante todo el periodo contratado.
                        </div>

                        <div class="subscription-price">
                            <div class="subscription-price-main">
                                @tipo.Precio.ToString("0.00") EUR
                            </div>

                            <small class="text-muted d-block mt-2">
                                IVA 21%: @iva.ToString("0.00") EUR
                            </small>

                            <small class="text-muted d-block">
                                Total final: @totalConIva.ToString("0.00") EUR
                            </small>
                        </div>

                        <div class="subscription-radio-dot"></div>
                    </div>
                </div>
            }
        </div>

        <div class="checkout-actions d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="text-muted small">
                Al confirmar, saldras a Stripe para completar el pago.
            </div>

            <button type="submit" class="btn btn-orange">
                <i class="bi bi-credit-card me-1"></i> Ir al pago
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const cards = document.querySelectorAll('.subscription-card');
            const hiddenInput = document.getElementById('TipoSuscripcionId');
            const form = document.getElementById('formContratarSuscripcion');
            const bloqueadoPorSuscripcion = @(Model.TieneSuscripcionActiva ? "true" : "false");

            function seleccionarSuscripcion(card) {
                const tipoId = card.getAttribute('data-tipo-id');

                hiddenInput.value = tipoId;

                cards.forEach(item => item.classList.remove('selected'));
                card.classList.add('selected');
            }

            cards.forEach(card => {
                card.addEventListener('click', function () {
                    if (bloqueadoPorSuscripcion) return;
                    seleccionarSuscripcion(this);
                });

                card.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        if (bloqueadoPorSuscripcion) return;
                        seleccionarSuscripcion(this);
                    }
                });
            });

            form.addEventListener('submit', function (e) {
                if (bloqueadoPorSuscripcion) {
                    e.preventDefault();

                    Swal.fire({
                        icon: 'info',
                        title: 'Suscripcion activa',
                        text: 'No puedes contratar otra suscripcion hasta que finalice la actual.',
                        confirmButtonColor: '#ff7a00'
                    });
                    return;
                }

                if (!hiddenInput.value || hiddenInput.value === '0') {
                    e.preventDefault();

                    Swal.fire({
                        icon: 'warning',
                        title: 'Selecciona una suscripcion',
                        text: 'Debes elegir un plan antes de continuar.',
                        confirmButtonColor: '#ff7a00'
                    });
                }
            });
        });
    </script>
}
