@model FitControlWeb.ViewModels.ClaseEditViewModel

@{
    ViewData["Title"] = "Editar clase";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" />
}

<div class="page-card">
    <div class="page-header">
        <h2 class="page-title">Editar clase</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Fecha" class="form-label"></label>
                <input asp-for="Fecha" type="date" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="HoraInicio" class="form-label"></label>
                <input asp-for="HoraInicio" type="time" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="HoraFin" class="form-label"></label>
                <input asp-for="HoraFin" type="time" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="CapacidadMinima" class="form-label"></label>
                <input asp-for="CapacidadMinima" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="CapacidadMaxima" class="form-label"></label>
                <input asp-for="CapacidadMaxima" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="EntrenadorId" class="form-label">Entrenador</label>
                <select asp-for="EntrenadorId" asp-items="ViewBag.Entrenadores" class="form-select"></select>
            </div>

            <div class="col-md-6">
                <label asp-for="EspecialidadId" class="form-label">Especialidad</label>
                <select asp-for="EspecialidadId" asp-items="ViewBag.Especialidades" class="form-select"></select>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 flex-wrap mt-4">
            <a href="@(string.IsNullOrWhiteSpace(ViewBag.ReturnUrl as string) ? Url.Action("Index", "Clases") : ViewBag.ReturnUrl)"
               class="btn btn-outline-secondary">
                Cancelar
            </a>

            <button class="btn btn-orange">
                <i class="bi bi-save me-1"></i> Guardar cambios
            </button>
        </div>
    </form>
</div>
