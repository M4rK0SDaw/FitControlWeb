@model FitControlWeb.ViewModels.Clases.ClaseIndexViewModel
@using FitControlWeb.ViewModels.Shared

@{
    ViewData["Title"] = "Clases";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
    <style>
        .clases-view-switch .btn.active {
            background: var(--gym-orange, #ff7a00);
            border-color: var(--gym-orange, #ff7a00);
            color: #fff;
        }

        #clasesCalendar {
            border: 1px solid #e7ebf1;
            border-radius: 16px;
            padding: 12px;
            background: #fff;
        }

        .fc .fc-toolbar-title {
            font-size: 1.15rem;
            font-weight: 800;
        }
    </style>
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">
                @(Model.EsCliente ? "Clases disponibles" : "Todas las clases")
            </h2>
            <p class="text-muted mb-0">
                @(Model.EsCliente
                    ? "Consulta clases y reserva si tienes suscripcion activa"
                    : "Gestion global de clases del gimnasio")
            </p>
        </div>

        <div class="d-flex gap-2 align-items-center flex-wrap">
            @if (User.IsInRole("Administrador"))
            {
                var exportModel = new ExportButtonsViewModel
                {
                    Controller = "Clases",
                    ExcelAction = "ExportExcel",
                    CsvAction = "ExportCsv",
                    PdfAction = "ExportPdf",
                    RouteValues = new Dictionary<string, string?>
                    {
                        { "search", Model.Search },
                        { "entrenadorId", Model.EntrenadorId?.ToString() },
                        { "especialidadId", Model.EspecialidadId?.ToString() },
                        { "estado", Model.Estado }
                    }
                };

                <partial name="_ExportButtons" model="exportModel" />

                <a asp-action="Create" class="btn btn-orange">
                    <i class="bi bi-plus-lg me-1"></i> Nueva Clase
                </a>
            }
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Nombre de clase..." />
            </div>

            @if (!Model.EsEntrenador)
            {
                <div class="col-md-3">
                    <label class="form-label">Entrenador</label>
                    <select name="entrenadorId" class="form-select">
                        <option value="">Todos</option>
                        @foreach (var item in Model.Entrenadores)
                        {
                            <option value="@item.Value" selected="@(Model.EntrenadorId?.ToString() == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>
            }

            <div class="col-md-3">
                <label class="form-label">Especialidad</label>
                <select name="especialidadId" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var item in Model.Especialidades)
                    {
                        <option value="@item.Value" selected="@(Model.EspecialidadId?.ToString() == item.Value)">
                            @item.Text
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="estado" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Estado))">Todas</option>
                    <option value="Disponibles" selected="@(Model.Estado == "Disponibles")">Disponibles</option>
                    <option value="Completas" selected="@(Model.Estado == "Completas")">Completas</option>
                    <option value="Finalizadas" selected="@(Model.Estado == "Finalizadas")">Finalizadas</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search me-1"></i> Buscar
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <div class="d-flex justify-content-end mb-3">
            <div class="btn-group clases-view-switch" role="group">
                <button type="button" class="btn btn-outline-secondary btn-clases-view active" data-view="tabla">
                    <i class="bi bi-table"></i> Tabla
                </button>
                <button type="button" class="btn btn-outline-secondary btn-clases-view" data-view="calendar">
                    <i class="bi bi-calendar3-week"></i> Calendario
                </button>
            </div>
        </div>

        <div id="clasesCalendarWrap" class="mb-4 d-none">
            <div id="clasesCalendar"></div>
        </div>

        <div id="clasesTablaWrap">
            <table class="table table-hover align-middle table-modern">
                <thead class="table-dark">
                    <tr>
                        <th>Clase</th>
                        <th>Especialidad</th>
                        <th>Fecha</th>
                        <th>Horario</th>
                        <th>Entrenador</th>
                        <th>Capacidad</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Clases.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                                No hay clases con los filtros seleccionados.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Clases)
                        {
                            <tr>
                                <td><strong>@c.Nombre</strong></td>
                                <td>
                                    <span class="badge bg-warning text-dark">@c.Especialidad</span>
                                </td>
                                <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <i class="bi bi-clock me-1 text-muted"></i>
                                    @c.HoraInicio - @c.HoraFin
                                </td>
                                <td>@c.Entrenador</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @c.PlazasOcupadas / @c.CapacidadMaxima plazas
                                    </span>
                                </td>
                                <td>
                                    @if (c.EsPasada)
                                    {
                                        <span class="badge bg-secondary">Finalizada</span>
                                    }
                                    else if (c.Completa)
                                    {
                                        <span class="badge bg-danger">Completa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Disponible</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Details"
                                           asp-route-id="@c.Id"
                                           class="btn btn-sm btn-outline-dark"
                                           title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@c.Id"
                                               asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-id="@c.Id"
                                                  method="post"
                                                  class="d-inline delete-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger btn-delete"
                                                        title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (User.IsInRole("Cliente"))
                                        {
                                            if (c.EsPasada)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" disabled>
                                                    <i class="bi bi-lock"></i> Finalizada
                                                </button>
                                            }
                                            else if (!c.ClienteTieneSuscripcionActiva)
                                            {
                                                <button class="btn btn-sm btn-outline-warning" disabled>
                                                    <i class="bi bi-exclamation-circle"></i> Necesitas suscripcion
                                                </button>
                                            }
                                            else if (c.YaReservada)
                                            {
                                                <button class="btn btn-sm btn-outline-info" disabled>
                                                    <i class="bi bi-check-circle"></i> Ya reservada
                                                </button>
                                            }
                                            else if (c.Completa)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" disabled>
                                                    <i class="bi bi-people-fill"></i> Completa
                                                </button>
                                            }
                                            else
                                            {
                                                <form asp-controller="Reservas"
                                                      asp-action="Reservar"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="claseId" value="@c.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                    <button type="submit" class="btn btn-sm btn-orange" title="Reservar">
                                                        <i class="bi bi-calendar-check"></i> Reservar
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
            <span class="text-muted small">
                Pagina @Model.CurrentPage de @Model.TotalPages
            </span>

            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="1"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-entrenadorId="@Model.EntrenadorId"
                           asp-route-especialidadId="@Model.EspecialidadId"
                           asp-route-estado="@Model.Estado">
                            <i class="bi bi-chevron-double-left"></i>
                        </a>
                    </li>

                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-entrenadorId="@Model.EntrenadorId"
                           asp-route-especialidadId="@Model.EspecialidadId"
                           asp-route-estado="@Model.Estado">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-entrenadorId="@Model.EntrenadorId"
                               asp-route-especialidadId="@Model.EspecialidadId"
                               asp-route-estado="@Model.Estado">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-entrenadorId="@Model.EntrenadorId"
                           asp-route-especialidadId="@Model.EspecialidadId"
                           asp-route-estado="@Model.Estado">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@Model.TotalPages"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-entrenadorId="@Model.EntrenadorId"
                           asp-route-especialidadId="@Model.EspecialidadId"
                           asp-route-estado="@Model.Estado">
                            <i class="bi bi-chevron-double-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        const botonesVista = document.querySelectorAll('.btn-clases-view');
        const tablaWrap = document.getElementById('clasesTablaWrap');
        const calendarWrap = document.getElementById('clasesCalendarWrap');
        let calendar = null;

        function setVista(tipo) {
            const esTabla = tipo === 'tabla';

            tablaWrap.classList.toggle('d-none', !esTabla);
            calendarWrap.classList.toggle('d-none', esTabla);

            botonesVista.forEach(btn => {
                btn.classList.toggle('active', btn.dataset.view === tipo);
            });

            if (!esTabla) {
                initCalendar();
                calendar?.render();
            }
        }

        function initCalendar() {
            if (calendar) return;

            const search = '@Model.Search';
            const entrenadorId = '@(Model.EntrenadorId?.ToString() ?? "")';
            const especialidadId = '@(Model.EspecialidadId?.ToString() ?? "")';
            const estado = '@(Model.Estado ?? "")';

            calendar = new FullCalendar.Calendar(document.getElementById('clasesCalendar'), {
                initialView: 'dayGridMonth',
                locale: 'es',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    prev: 'Anterior',
                    next: 'Siguiente',
                    today: 'Hoy',
                    month: 'Mes',
                    week: 'Semana',
                    day: 'Dia'
                },
                buttonHints: {
                    prev: 'Ir al periodo anterior',
                    next: 'Ir al periodo siguiente',
                    today: 'Ir a hoy',
                    month: 'Vista mensual',
                    week: 'Vista semanal',
                    day: 'Vista diaria'
                },
                viewHint: 'Vista {0}',
                height: 'auto',
                events: `/Clases/CalendarEvents?search=${encodeURIComponent(search)}&entrenadorId=${encodeURIComponent(entrenadorId)}&especialidadId=${encodeURIComponent(especialidadId)}&estado=${encodeURIComponent(estado)}`,
                eventClick: function (info) {
                    const id = info.event.id;
                    if (id) {
                        window.location.href = `/Clases/Details/${id}`;
                    }
                }
            });
        }

        botonesVista.forEach(btn => {
            btn.addEventListener('click', function() {
                setVista(this.dataset.view);
            });
        });

        document.querySelectorAll('.btn-delete').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: '¿Dar de baja esta clase?',
                    text: 'La clase no se borrara fisicamente, quedara inactiva.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Si, dar de baja',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}
