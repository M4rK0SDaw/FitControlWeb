@model FitControlWeb.ViewModels.Facturas.FacturaIndexViewModel
@using FitControlWeb.ViewModels.Shared

@{
    ViewData["Title"] = "Facturas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CrudStyle.css" asp-append-version="true" />
}

<div class="page-card">

    <div class="page-header flex-wrap gap-3">
        <div>
            <h2 class="page-title">Facturas</h2>
            <p class="text-muted mb-0">Listado de facturas generadas y estado de cobro</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Facturas encontradas</span>
                <p class="info-value mb-0">@Model.TotalFacturas</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Pagadas en pagina</span>
                <p class="info-value mb-0">@Model.TotalPagadas</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Pendientes en pagina</span>
                <p class="info-value mb-0">@Model.TotalPendientes</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="info-box">
                <span class="info-label">Importe pagina</span>
                <p class="info-value mb-0">@Model.ImportePagina.ToString("0.00") EUR</p>
            </div>
        </div>
    </div>

    <div class="filter-box mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Nº factura, cliente o email..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="pagada" class="form-select">
                    <option value="">Todas</option>
                    <option value="true" selected="@(Model.Pagada == true)">Pagadas</option>
                    <option value="false" selected="@(Model.Pagada == false)">Pendientes</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Ver</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-orange w-100">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
        <br />
        @{
            var exportModel = new ExportButtonsViewModel
            {
                Controller = "Facturas",
                ExcelAction = "ExportExcel",
                CsvAction = "ExportCsv",
                PdfAction = "ExportPdf",
                RouteValues = new Dictionary<string, string?>
                {
                    { "search", Model.Search },
                    { "pagada", Model.Pagada?.ToString() }
                }
            };
        }

        <partial name="_ExportButtons" model="exportModel" />
    </div>

    @if (!Model.Facturas.Any())
    {
        <div class="alert alert-info">
            No hay facturas con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nº factura</th>
                        <th>Cliente</th>
                        <th>Concepto</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var f in Model.Facturas)
                    {
                        var concepto = f.FacturaDetalles?
                            .Where(d => !string.IsNullOrWhiteSpace(d.Concepto))
                            .Select(d => d.Concepto)
                            .FirstOrDefault();

                        <tr>
                            <td class="fw-semibold">@f.NumeroFactura</td>

                            <td>
                                @(f.Usuario != null
                                    ? $"{f.Usuario.Nombre} {f.Usuario.Apellidos}"
                                    : "Sin cliente")
                                <br />
                                <small class="text-muted">@f.Usuario?.Email</small>
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(concepto) ? "Sin concepto" : concepto)
                            </td>

                            <td>@f.FechaEmision?.ToString("dd/MM/yyyy HH:mm")</td>

                            <td class="fw-bold">@f.Total.ToString("0.00") EUR</td>

                            <td>
                                @if (f.Pagada == true)
                                {
                                    <span class="badge bg-success">Pagada</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                       asp-route-id="@f.Id"
                                       class="btn btn-sm btn-outline-dark"
                                       title="Ver factura">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (f.Pagada != true)
                                    {
                                        <form asp-action="PagarConStripe"
                                              asp-route-id="@f.Id"
                                              method="post"
                                              class="d-inline form-stripe">
                                            @Html.AntiForgeryToken()

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success btn-stripe"
                                                    title="Pagar con Stripe">
                                                <i class="bi bi-credit-card"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">

                <span class="text-muted small">
                    Pagina @Model.CurrentPage de @Model.TotalPages
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="1"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-pagada="@Model.Pagada">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-pagada="@Model.Pagada">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-pagada="@Model.Pagada">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-pagada="@Model.Pagada">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@Model.TotalPages"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search"
                               asp-route-pagada="@Model.Pagada">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-stripe').forEach(button => {
            button.addEventListener('click', function () {
                const form = this.closest('form');

                Swal.fire({
                    title: 'Pago seguro con Stripe',
                    text: 'Se abrira el flujo de pago de la factura.',
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#ff7a00',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Continuar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}
