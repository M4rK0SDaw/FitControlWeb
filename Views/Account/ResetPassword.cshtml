@model FitControlWeb.ViewModels.Auth.ResetPasswordViewModel

@{
    ViewData["Title"] = "Nueva contraseña";
}

@section Styles {
    <style>
        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(rgba(17, 19, 24, .80), rgba(17, 19, 24, .80)), url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1600&q=80');
            background-size: cover;
            background-position: center;
        }

        .auth-card {
            width: 100%;
            max-width: 460px;
            background: #fff;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 20px 60px rgba(0,0,0,.35);
        }

        .btn-orange {
            background: #ff7a00;
            color: #fff;
            border: none;
        }

            .btn-orange:hover {
                background: #e86f00;
                color: #fff;
            }
    </style>
}

<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold mb-1">Nueva contraseña</h2>
            <p class="text-muted mb-0">Introduce tu nueva contraseña.</p>
        </div>

        <form asp-action="ResetPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Nueva contraseña</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Repetir contraseña</label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-orange w-100">
                Cambiar contraseña
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}