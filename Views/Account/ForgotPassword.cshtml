@model FitControlWeb.ViewModels.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar contraseña";
}

@section Styles {
    <style>
        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(rgba(17, 19, 24, .80), rgba(17, 19, 24, .80)), url('https://images.unsplash.com/photo-1571902943202-507ec2618e8f?auto=format&fit=crop&w=1600&q=80');
            background-size: cover;
            background-position: center;
        }

        .auth-card {
            width: 100%;
            max-width: 460px;
            background: #fff;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 20px 60px rgba(0,0,0,.35);
        }

        .btn-orange {
            background: #ff7a00;
            color: #fff;
            border: none;
        }

            .btn-orange:hover {
                background: #e86f00;
                color: #fff;
            }
    </style>
}

<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold mb-1">Recuperar contraseña</h2>
            <p class="text-muted mb-0">Introduce tu email y te enviaremos un enlace.</p>
        </div>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 d-none" data-fit-validation-toast="true"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="tuemail@correo.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-orange w-100">
                Enviar enlace
            </button>

            <div class="text-center mt-3">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                    Volver al login
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
